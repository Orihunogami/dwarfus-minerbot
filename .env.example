# токен бота от @BotFather
BOT_TOKEN=

# ключ шифрования паролей — сгенерируй командой:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# строка подключения к PostgreSQL
DATABASE_URL=postgresql://gm:gmpass@localhost:5432/goldenminer

# ключ CoinMarketCap для курсов (необязательно; без него бот работает, но без сумм в $)
CMC_API_KEY=

# GitHub токен для слежения за версиями (необязательно; поднимает лимит запросов)
GITHUB_TOKEN=

# токен HiveOS API (риг-сторона: фермы, воркеры, хешрейт по картам)
HIVE_TOKEN=

# как часто проверять версии репозиториев (минут)
VERSION_CHECK_MINUTES=60

# как часто опрашивать аккаунты (минут)
POLL_MINUTES=10

# смещение часового пояса для границы "дня" при расчёте доходности (3 = МСК, 0 = UTC)
DAY_TZ_OFFSET_HOURS=3
